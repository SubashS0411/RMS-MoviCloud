# Backend Environment Variables
# You can override these by creating a .env file in the backend directory

# -- General Settings --
ENVIRONMENT=development
SECRET_KEY=a-very-secret-key-that-you-should-change
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# -- Database --
# Choose 'mongodb' or 'inmemory'
DB_TYPE=mongodb
DB_URL=mongodb://localhost:27017/
DB_NAME=rms_db
# For in-memory DB, you can leave the above two empty

# -- Google Drive (Optional) --
# Used for backups and file storage. Leave empty if not used.
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_CREDENTIALS_PATH=credentials.json

# -- Twilio (Optional) --
# Used for SMS notifications. Leave empty if not used.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -- Email (Optional) --
# Used for sending email notifications. Leave empty if not used.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.example.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
